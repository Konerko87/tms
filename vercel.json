{
  "rewrites": [
    {
      "source": "/checkin/(.*)",
      "destination": "https://logistics-tms-production.up.railway.app/checkin/$1"
    },
    {
      "source": "/(.*)",
      "destination": "https://logistics-tms-production.up.railway.app/checkin/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
